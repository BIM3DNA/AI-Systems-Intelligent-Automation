<Window x:Name="MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AI Workbench"
    Height="640"
    Width="1100"
    MinWidth="980"
    MinHeight="680"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    Background="#eff6ff"
    ResizeMode="CanResizeWithGrip"
    SizeToContent="Manual"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="ComboBackgroundBrush" Color="#f8fafd"/>
        <SolidColorBrush x:Key="ComboForegroundBrush" Color="#1f2937"/>
        <SolidColorBrush x:Key="ComboBorderBrush" Color="#b3cef6"/>
        <SolidColorBrush x:Key="ComboItemBackgroundBrush" Color="#ffffff"/>
        <SolidColorBrush x:Key="ComboItemForegroundBrush" Color="#1f2937"/>
        <SolidColorBrush x:Key="ComboItemHighlightBrush" Color="#dbeafe"/>
        <SolidColorBrush x:Key="ComboItemHighlightForegroundBrush" Color="#1f2937"/>
        <SolidColorBrush x:Key="TreeBackgroundBrush" Color="#f8fafd"/>
        <SolidColorBrush x:Key="TreeForegroundBrush" Color="#1f2937"/>
        <SolidColorBrush x:Key="TreeItemHoverBrush" Color="#e0efff"/>
        <SolidColorBrush x:Key="TreeItemSelectedBrush" Color="#dbeafe"/>
        <SolidColorBrush x:Key="TreeItemSelectedForegroundBrush" Color="#1f2937"/>
        <SolidColorBrush x:Key="TreeBorderBrush" Color="#b3cef6"/>
        <SolidColorBrush x:Key="ButtonDisabledBackgroundBrush" Color="#233143"/>
        <SolidColorBrush x:Key="ButtonDisabledForegroundBrush" Color="#8a97ab"/>
        <SolidColorBrush x:Key="ButtonDisabledBorderBrush" Color="#42526a"/>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Opacity" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource ButtonDisabledBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ButtonDisabledForegroundBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource ButtonDisabledBorderBrush}"/>
                    <Setter Property="Opacity" Value="0.96"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ComboBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBorderBrush}"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource ComboItemBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboItemForegroundBrush}"/>
            <Setter Property="Padding" Value="6,2"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ComboItemHighlightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ComboItemHighlightForegroundBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ComboItemHighlightBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ComboItemHighlightForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="{DynamicResource TreeBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TreeForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TreeBorderBrush}"/>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{DynamicResource TreeForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource TreeBackgroundBrush}"/>
            <Setter Property="Padding" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TreeItemHoverBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TreeItemSelectedForegroundBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TreeItemSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TreeItemSelectedForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border x:Name="MainBorder" CornerRadius="16" BorderBrush="#7aaef7" BorderThickness="2" Background="White" Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid x:Name="HeaderBar" Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="12,0,16,0">
                    <TextBlock x:Name="HeaderTitle" Text="AI Workbench" VerticalAlignment="Center" FontWeight="Bold" FontSize="20" Foreground="#1f2937"/>
                    <TextBlock x:Name="HeaderSubtitle" Text="Single Revit entry point for chat, ModelMind recipes, and guarded agent planning." FontSize="11" Foreground="#4b5563"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button x:Name="ThemeToggleButton" Content="Theme: Light" Width="110" Height="28" Margin="10,0,0,0" Background="#f8fafd" Foreground="#1f2937" BorderBrush="#7aaef7" BorderThickness="1" ToolTip="Toggle light and dark window themes. The selection is saved locally."/>
                    <Button x:Name="CloseButton" Content="Close" Width="64" Height="28" Margin="10,0,0,0" Background="#0085ff" Foreground="White" BorderBrush="#0085ff" BorderThickness="1" ToolTip="Close AI Workbench. Reopen it from the ribbon when you want to continue."/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,6,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ModelInfo" Grid.Column="0" Text="Model: Loading..." FontWeight="Bold" Foreground="#0085ff" FontSize="14" VerticalAlignment="Center"/>
                <Button x:Name="UpgradeButton" Grid.Column="1" Content="Upgrade Model" Width="110" Height="24" Margin="14,0,0,0" FontSize="12" Background="#e0eaff" Foreground="#0066cc" BorderBrush="#0066cc" BorderThickness="1"/>
                <ComboBox x:Name="ModelSelector" Grid.Column="2" Width="200" Height="24" Margin="14,0,0,0" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusLabel" Grid.Column="3" Text="Ready" FontWeight="Bold" Foreground="#0085ff" FontSize="13" Margin="18,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
                <ProgressBar x:Name="BusyBar" Height="8" Width="140" IsIndeterminate="True" Visibility="Collapsed" Foreground="#0085ff" Background="#e0eaff"/>
                <TextBlock x:Name="ThinkingLabel" Text="Thinking..." Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#0085ff" FontSize="14" Visibility="Collapsed"/>
            </StackPanel>

            <TabControl x:Name="MainTabs" Grid.Row="3" Margin="0,10,0,0">
                <TabItem Header="Ollama Chat" ToolTip="Low-risk conversational help and prompt experimentation using the selected Ollama model.">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="360" MinWidth="280"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="ChatHelpText" Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" TextWrapping="Wrap" Foreground="#4b5563" Text="Ollama Chat can answer from a read-only Revit project-context scan. Start with Scan Project, then ask project questions or ask AI Agent for a reviewed plan."/>
                        <RichTextBox x:Name="ChatHistory" Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" IsReadOnly="True" Background="#f8fafd" FontSize="15" BorderBrush="#b3cef6" BorderThickness="1" Margin="0,0,8,0"/>
                        <Grid Grid.Row="2" Grid.Column="0" Margin="0,10,8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ChatInput" Height="32" MaxHeight="80" MinWidth="390" MaxWidth="760" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontSize="14" BorderBrush="#b3cef6" BorderThickness="1" Margin="0,0,10,0" Grid.Column="0"/>
                            <Button x:Name="SendButton" Content="Send" Width="90" Height="32" Background="#0085ff" Foreground="White" FontWeight="Bold" BorderBrush="#0085ff" BorderThickness="1" FontSize="14" Grid.Column="1"/>
                        </Grid>
                        <GridSplitter x:Name="ProjectContextSplitter" Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#dbeafe" ResizeBehavior="PreviousAndNext" ShowsPreview="True"/>
                        <Border x:Name="ProjectContextPanelBorder" Grid.Row="0" Grid.RowSpan="3" Grid.Column="2" MinWidth="280" BorderBrush="#b3cef6" BorderThickness="1" Background="#f8fafd" Padding="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="ProjectContextTitleText" Text="Project Context" FontWeight="Bold" Foreground="#1f2937" Margin="0,0,0,4"/>
                                <TextBlock x:Name="ProjectContextStatusText" Grid.Row="1" Text="Not scanned" TextWrapping="Wrap" Foreground="#4b5563" Margin="0,0,0,8"/>
                                <WrapPanel Grid.Row="2" Margin="0,0,0,8">
                                    <Button x:Name="ProjectScanButton" Content="Scan Project" Width="104" Height="26" Margin="0,0,6,6" Background="#0085ff" Foreground="White" BorderBrush="#0085ff" BorderThickness="1" ToolTip="Run a standard read-only project context scan."/>
                                    <Button x:Name="ProjectRefreshButton" Content="Refresh Context" Width="120" Height="26" Margin="0,0,6,6" Background="#f8fafd" Foreground="#1f2937" BorderBrush="#b3cef6" BorderThickness="1" ToolTip="Refresh the standard project context scan."/>
                                    <Button x:Name="ProjectAgentPlanButton" Content="Ask Agent for Plan" Width="132" Height="26" Margin="0,0,6,6" Background="#6c5ce7" Foreground="White" BorderBrush="#6c5ce7" BorderThickness="1" ToolTip="Create a reviewed AI Agent plan from the latest scan."/>
                                    <Button x:Name="ProjectCodexBriefButton" Content="Create Codex Brief" Width="132" Height="26" Margin="0,0,6,6" Background="#475569" Foreground="White" BorderBrush="#475569" BorderThickness="1" ToolTip="Create a copyable developer task brief from the latest scan."/>
                                </WrapPanel>
                                <WrapPanel Grid.Row="3" Margin="0,0,0,8">
                                    <Button x:Name="ProjectQuickSummaryButton" Tag="summary" Content="Summary" Width="76" Height="24" Margin="0,0,5,5"/>
                                    <Button x:Name="ProjectQuickLevelsButton" Tag="levels" Content="Levels" Width="68" Height="24" Margin="0,0,5,5"/>
                                    <Button x:Name="ProjectQuickViewsButton" Tag="views" Content="Views" Width="64" Height="24" Margin="0,0,5,5"/>
                                    <Button x:Name="ProjectQuickSheetsButton" Tag="sheets" Content="Sheets" Width="66" Height="24" Margin="0,0,5,5"/>
                                    <Button x:Name="ProjectQuickLinksButton" Tag="links" Content="Links" Width="62" Height="24" Margin="0,0,5,5"/>
                                    <Button x:Name="ProjectQuickImportsButton" Tag="imports" Content="CAD / Imports" Width="104" Height="24" Margin="0,0,5,5"/>
                                    <Button x:Name="ProjectQuickCategoriesButton" Tag="categories" Content="Categories" Width="88" Height="24" Margin="0,0,5,5"/>
                                    <Button x:Name="ProjectQuickSchedulesButton" Tag="schedules" Content="Schedules" Width="82" Height="24" Margin="0,0,5,5"/>
                                    <Button x:Name="ProjectQuickEmptySchedulesButton" Tag="empty schedules" Content="Empty / Suspicious" Width="126" Height="24" Margin="0,0,5,5"/>
                                    <Button x:Name="ProjectQuickWarningsButton" Tag="warnings" Content="Warnings" Width="82" Height="24" Margin="0,0,5,5"/>
                                    <Button x:Name="ProjectQuickIssuesButton" Tag="issues" Content="Issues" Width="64" Height="24" Margin="0,0,5,5"/>
                                    <Button x:Name="ProjectQuickFirstChecksButton" Tag="first checks" Content="First Checks" Width="92" Height="24" Margin="0,0,5,5"/>
                                </WrapPanel>
                                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="{DynamicResource TreeBackgroundBrush}" BorderBrush="{DynamicResource TreeBorderBrush}" BorderThickness="1">
                                    <TreeView x:Name="ProjectContextTree" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="AI Agent" ToolTip="Smaller deterministic reviewed-planner for supported BIM checks and selections.">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="AgentIntroText" Grid.Row="0" Margin="0,0,0,6" TextWrapping="Wrap" Foreground="#4b5563" Text="AI Agent is a smaller deterministic reviewed-planner. It only supports a narrow set of BIM workflow plans for now."/>
                        <TextBlock x:Name="AgentWarningText" Grid.Row="1" Margin="0,0,0,8" TextWrapping="Wrap" Foreground="#ef4444" FontWeight="Bold" Text="Destructive tools are OFF by default. Review plans first; modifying commands remain blocked."/>

                        <Grid Grid.Row="2" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Planner mode:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#1f2937" FontWeight="Bold"/>
                            <ComboBox x:Name="AgentRuntimeSelector" Grid.Column="1" Width="210" Height="26" VerticalAlignment="Center" ToolTip="Choose Local deterministic planning or OpenAI-backed intent normalization when available.">
                                <ComboBoxItem Content="Local deterministic planner" IsSelected="True"/>
                                <ComboBoxItem Content="OpenAI planner"/>
                            </ComboBox>
                            <TextBlock x:Name="AgentProviderLabel" Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="#4b5563" FontWeight="Bold" Text="Planner provider: Local"/>
                            <CheckBox x:Name="AgentAllowDestructive" Grid.Column="3" Margin="16,0,0,0" VerticalAlignment="Center" Content="Allow destructive tools" ToolTip="Disabled by default. When enabled, modifying commands in the reviewed plan may change or delete model data."/>
                            <TextBlock x:Name="AgentStatus" Grid.Column="4" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="#0085ff" FontWeight="Bold" Text="Planner ready"/>
                        </Grid>

                        <TextBlock x:Name="AgentProviderHelp" Grid.Row="3" Margin="0,0,0,8" TextWrapping="Wrap" Foreground="#4b5563" Text="Local deterministic planning is always available. OpenAI planning needs OPENAI_API_KEY and only normalizes requests into supported reviewed actions."/>

                        <RichTextBox x:Name="AgentHistory" Grid.Row="4" VerticalScrollBarVisibility="Auto" IsReadOnly="True" Background="#f8fafd" FontSize="15" BorderBrush="#b3cef6" BorderThickness="1"/>

                        <Grid Grid.Row="5" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AgentGoalInput" Height="32" MaxHeight="80" MinWidth="390" MaxWidth="820" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontSize="14" BorderBrush="#b3cef6" BorderThickness="1" Margin="0,0,10,0" Grid.Column="0" ToolTip="Describe the result you want. Run Agent will produce a reviewed plan; Execute Plan runs the enabled steps."/>
                            <Button x:Name="AgentRunButton" Content="Plan Request" Width="140" Height="32" Background="#6c5ce7" Foreground="White" FontWeight="Bold" BorderBrush="#6c5ce7" BorderThickness="1" FontSize="14" Grid.Column="1" ToolTip="Generate or refresh a supported deterministic plan only."/>
                            <Button x:Name="AgentExecuteButton" Content="Execute Plan" Width="140" Height="32" Background="#0984e3" Foreground="White" FontWeight="Bold" BorderBrush="#0984e3" BorderThickness="1" FontSize="14" Grid.Column="2" IsEnabled="False" ToolTip="Execute the currently reviewed plan."/>
                        </Grid>

                        <Grid Grid.Row="6" Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="AgentCommandLegend" Grid.Row="0" Grid.ColumnSpan="5" Margin="0,0,0,6" TextWrapping="Wrap" Foreground="#4b5563" Text="Supported reviewed actions are shown here for reference. The control below selects only the current reviewed plan steps."/>
                            <TextBlock x:Name="AgentPlanStepLabel" Grid.Row="1" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#1f2937" FontWeight="Bold" Text="Current Plan Steps:"/>
                            <ComboBox x:Name="AgentCommandSelector" Grid.Row="1" Grid.Column="1" Height="26" Margin="0,0,10,0" VerticalAlignment="Center" ToolTip="Shows only the reviewed steps in the current plan."/>
                            <Button x:Name="AgentToggleCommandButton" Content="Disable/Enable" Width="120" Height="26" Background="#ffeaa7" Foreground="#2d3436" BorderBrush="#ffeaa7" BorderThickness="1" Grid.Row="1" Grid.Column="2" ToolTip="Enable or disable the selected planned command for this session."/>
                            <Button x:Name="AgentResetCommandsButton" Content="Reset Commands" Width="120" Height="26" Background="#fab1a0" Foreground="#2d3436" BorderBrush="#fab1a0" BorderThickness="1" Grid.Row="1" Grid.Column="3" Margin="10,0,0,0" ToolTip="Clear the current plan and session command state."/>
                            <Button x:Name="AgentUndoButton" Content="Undo Last Action" Width="130" Height="26" Background="#dfe6e9" Foreground="#2d3436" BorderBrush="#dfe6e9" BorderThickness="1" Grid.Row="1" Grid.Column="4" Margin="10,0,0,0" IsEnabled="False" ToolTip="Disabled because robust rollback and journaling are not implemented yet."/>
                            <TextBlock x:Name="AgentStepStateText" Grid.Row="2" Grid.ColumnSpan="5" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#4b5563" Text="No current reviewed plan. Plan Request creates the current reviewed plan steps."/>
                            <TextBlock x:Name="AgentUndoStatusText" Grid.Row="3" Grid.ColumnSpan="5" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#4b5563" Text="Undo unavailable: no reversible action in current session."/>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="ModelMind" ToolTip="Primary workflow for deterministic BIM task recipes and reviewed semi-generative code generation.">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="ModelMindIntroText" Grid.Row="0" Grid.Column="0" Margin="0,0,10,8" TextWrapping="Wrap" Foreground="#4b5563" Text="ModelMind is the primary task surface for most users. Use the structured prompt catalog for deterministic and semi-generative BIM workflows. Approved recipes are shown in a separate branch."/>
                        <Grid Grid.Row="1" Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="ReviewedCodeStateLabel" Grid.Row="0" Margin="0,0,10,8" TextWrapping="Wrap" Foreground="#0085ff" FontWeight="Bold" Text="Reviewed code state: draft"/>
                            <RichTextBox x:Name="ModelMindHistory" Grid.Row="1" VerticalScrollBarVisibility="Auto" IsReadOnly="True" Background="#f8fafd" FontSize="15" BorderBrush="#b3cef6" BorderThickness="1"/>
                        </Grid>
                        <GroupBox x:Name="ReviewedCodeGroup" Header="Reviewed Code" Grid.Row="2" Grid.Column="0" Margin="0,10,10,0" Visibility="Collapsed">
                            <TextBox x:Name="ReviewedCodePreview" AcceptsReturn="True" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="120" MaxHeight="180" BorderThickness="0" Background="#f8fafd" Foreground="#1f2937"/>
                        </GroupBox>

                        <Grid Grid.Row="3" Grid.Column="0" Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBox x:Name="ModelMindInput" Grid.Row="0" MinHeight="32" MaxHeight="90" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontSize="14" BorderBrush="#b3cef6" BorderThickness="1" Margin="0,0,0,10" HorizontalAlignment="Stretch" ToolTip="Enter a deterministic recipe prompt or a semi-generative BIM task request. The catalog filter on the right is read-only and separate from this input."/>
                            <WrapPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" ItemHeight="32" ItemWidth="170">
                                <Button x:Name="ModelMindSendButton" Content="Send" Width="110" Height="32" Background="#00b894" Foreground="White" FontWeight="Bold" BorderBrush="#00b894" BorderThickness="1" FontSize="14" Margin="0,0,10,8"/>
                                <Button x:Name="ToggleReviewedCodeButton" Content="Show reviewed code" Width="150" Height="32" Background="#475569" Foreground="White" FontWeight="Bold" BorderBrush="#475569" BorderThickness="1" FontSize="12" Margin="0,0,10,8" IsEnabled="False" ToolTip="Show or hide the reviewed code draft."/>
                                <Button x:Name="ApproveCodeButton" Content="Approve &amp; Run Code" Width="160" Height="32" Background="#e17055" Foreground="White" FontWeight="Bold" BorderBrush="#e17055" BorderThickness="1" FontSize="14" Margin="0,0,10,8" ToolTip="Run reviewed generated code only after validation."/>
                                <Button x:Name="SaveRecipeButton" Content="Save as Approved Recipe" Width="180" Height="32" Background="#3b82f6" Foreground="White" FontWeight="Bold" BorderBrush="#3b82f6" BorderThickness="1" FontSize="13" Margin="0,0,10,8" IsEnabled="False" ToolTip="Available only after a successful reviewed-code execution."/>
                                <Button x:Name="ModelMindUndoButton" Content="Undo Last Action" Width="150" Height="32" Background="#dfe6e9" Foreground="#2d3436" FontWeight="Bold" BorderBrush="#dfe6e9" BorderThickness="1" FontSize="13" Margin="0,0,10,8" IsEnabled="False" ToolTip="Available only when a real reversible reviewed action exists in the current session."/>
                            </WrapPanel>
                        </Grid>

                        <GridSplitter x:Name="ModelMindSplitter" Grid.Row="0" Grid.RowSpan="4" Grid.Column="1" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#dbeafe" ResizeBehavior="PreviousAndNext"/>

                        <Grid Grid.Row="0" Grid.Column="2" Grid.RowSpan="4" Margin="10,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <GroupBox x:Name="PromptDetailsGroup" Header="Selected Action Details" Grid.Row="0" Margin="0,0,0,8">
                                <Grid Margin="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="PromptDetailTitle" Grid.Row="0" Text="Select a reviewed action" FontWeight="Bold" TextWrapping="Wrap" Foreground="#1f2937"/>
                                    <TextBlock x:Name="PromptDetailMeta" Grid.Row="1" Margin="0,6,0,0" Text="Role, risk, validation state, and agent availability will appear here." TextWrapping="Wrap" Foreground="#4b5563"/>
                                    <TextBox x:Name="PromptDetailBody" Grid.Row="2" Margin="0,8,0,0" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="120" MaxHeight="190" BorderThickness="0" Background="#f8fafd" Foreground="#1f2937"/>
                                </Grid>
                            </GroupBox>
                            <Grid Grid.Row="1" Margin="0,0,0,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PromptCatalogSearchBox" Grid.Row="0" Grid.Column="0" Height="28" Margin="0,0,8,0" BorderBrush="#b3cef6" BorderThickness="1" ToolTip="Filter the reviewed catalog by title, aliases, examples, and grouping metadata. This search does not run actions."/>
                                <Button x:Name="PromptCatalogClearButton" Grid.Row="0" Grid.Column="1" Width="58" Height="28" Margin="0,0,8,0" Background="#f8fafd" Foreground="#1f2937" BorderBrush="#b3cef6" BorderThickness="1" Content="Clear" ToolTip="Clear the catalog filter. This affects only the catalog tree."/>
                                <Button x:Name="PromptTreeExpandButton" Grid.Row="0" Grid.Column="2" Width="82" Height="28" Margin="0,0,8,0" Background="#f8fafd" Foreground="#1f2937" BorderBrush="#b3cef6" BorderThickness="1" Content="Expand All" ToolTip="Expand the currently visible catalog branches."/>
                                <Button x:Name="PromptTreeCollapseButton" Grid.Row="0" Grid.Column="3" Width="88" Height="28" Background="#f8fafd" Foreground="#1f2937" BorderBrush="#b3cef6" BorderThickness="1" Content="Collapse All" ToolTip="Collapse the currently visible catalog branches."/>
                                <TextBlock x:Name="PromptCatalogStatusText" Grid.Row="1" Grid.ColumnSpan="4" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#4b5563" Text="Catalog filter only. Search titles, aliases, and examples without running any action."/>
                            </Grid>
                            <TextBlock x:Name="PromptTreeHint" Grid.Row="2" Margin="0,0,0,8" TextWrapping="Wrap" Foreground="#4b5563" Text="Use the catalog filter to browse the shared reviewed catalog. Recent Prompts remain convenience shortcuts only and still resolve back to canonical reviewed action metadata."/>
                            <GroupBox x:Name="PromptTreeGroup" Header="Reviewed Action Catalog" Grid.Row="3" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" ToolTip="Filtered, grouped view of the shared reviewed catalog. The catalog filter narrows entries only; it does not run actions.">
                                <TreeView x:Name="PromptTree" BorderBrush="#b3cef6" BorderThickness="1"/>
                            </GroupBox>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
