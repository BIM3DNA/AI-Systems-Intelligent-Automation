<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Zonneveld Copilot AI" Height="520" Width="1000" WindowStartupLocation="CenterScreen" WindowStyle="None" Background="#eff6ff" ResizeMode="NoResize">
    <Border CornerRadius="16" BorderBrush="#0085ff" BorderThickness="2" Background="White" Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel x:Name="HeaderBar" Grid.Row="0" Margin="0,0,0,8" Cursor="Hand">
                <Image Source="https://www.zonneveld.com/images/Zonneveld_logo_web.png" Height="40" Width="120" Stretch="Uniform"/>
                <TextBlock Text="AIChat" VerticalAlignment="Center" FontWeight="Bold" FontSize="20" Margin="12,0,0,0" Foreground="#333"/>
                <Button x:Name="CloseButton" Content="Close" Width="55" Height="26" Margin="10,0,0,0" HorizontalAlignment="Right" DockPanel.Dock="Right" Background="#0085ff" Foreground="White" BorderBrush="#0085ff" BorderThickness="1"/>
            </DockPanel>

            <!-- Model & Upgrade row (above tab control) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,6,0,6">
                <TextBlock x:Name="ModelInfo" Text="Model: Loading..." FontWeight="Bold" Foreground="#0085ff" FontSize="14" VerticalAlignment="Center"/>
                <Button x:Name="UpgradeButton" Content="Upgrade Model" Width="110" Height="22" Margin="14,0,0,0" FontSize="12" Background="#e0eaff" Foreground="#0066cc" BorderBrush="#0066cc" BorderThickness="1"/>
                <ComboBox x:Name="ModelSelector" Width="180" Height="22" Margin="14,0,0,0" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
                <ProgressBar x:Name="BusyBar" Height="8" Width="140" IsIndeterminate="True" Visibility="Collapsed" Foreground="#0085ff" Background="#e0eaff"/>
                <TextBlock x:Name="ThinkingLabel" Text="Thinking..." Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#0085ff" FontSize="14" Visibility="Collapsed"/>
            </StackPanel>

            <!-- Main TabControl -->
            <TabControl Grid.Row="3" Margin="0,10,0,0">
                <!-- Ollama Chat Tab -->
                <TabItem Header="Ollama Chat">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <RichTextBox x:Name="ChatHistory" Grid.Row="0" VerticalScrollBarVisibility="Auto" IsReadOnly="True" Background="#f8fafd" FontSize="15" BorderBrush="#b3cef6" BorderThickness="1"/>
                        <Grid Grid.Row="1" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ChatInput" Height="32" MaxHeight="80" MinWidth="390" MaxWidth="600" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontSize="14" BorderBrush="#b3cef6" BorderThickness="1" Margin="0,0,10,0" Grid.Column="0"/>
                            <Button x:Name="SendButton" Content="Send" Width="90" Height="32" Background="#0085ff" Foreground="White" FontWeight="Bold" BorderBrush="#0085ff" BorderThickness="1" FontSize="14" Grid.Column="1"/>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- AI Agent Tab (NEW) -->
                <TabItem Header="AI Agent">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Runtime selector row -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Agent runtime:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#333" FontWeight="Bold"/>
                            <ComboBox x:Name="AgentRuntimeSelector" Grid.Column="1" Width="210" Height="26" VerticalAlignment="Center">
                                <ComboBoxItem Content="Auto (Cloud + Local)" IsSelected="True"/>
                                <ComboBoxItem Content="Cloud: GPT Agent"/>
                                <ComboBoxItem Content="Local: Ollama Agent"/>
                            </ComboBox>

                            <CheckBox x:Name="AgentAllowDestructive" Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center" Content="Allow destructive tools" />
                            <TextBlock x:Name="AgentStatus" Grid.Column="3" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="#0085ff" Text="Idle"/>
                        </Grid>

                        <!-- Transcript -->
                        <RichTextBox x:Name="AgentHistory" Grid.Row="1" VerticalScrollBarVisibility="Auto" IsReadOnly="True" Background="#f8fafd" FontSize="15" BorderBrush="#b3cef6" BorderThickness="1" />

                        <!-- Goal + Run -->
                        <Grid Grid.Row="2" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AgentGoalInput" Height="32" MaxHeight="80" MinWidth="390" MaxWidth="800" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontSize="14" BorderBrush="#b3cef6" BorderThickness="1" Margin="0,0,10,0" Grid.Column="0" />
                            <Button x:Name="AgentRunButton" Content="Run Agent" Width="140" Height="32" Background="#6c5ce7" Foreground="White" FontWeight="Bold" BorderBrush="#6c5ce7" BorderThickness="1" FontSize="14" Grid.Column="1"/>
                            <Button x:Name="AgentExecuteButton" Content="Execute Plan" Width="140" Height="32" Background="#0984e3" Foreground="White" FontWeight="Bold" BorderBrush="#0984e3" BorderThickness="1" FontSize="14" Grid.Column="2" IsEnabled="False"/>
                        </Grid>

                        <!-- Command management -->
                        <Grid Grid.Row="3" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="AgentCommandSelector" Grid.Column="0" Height="26" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <Button x:Name="AgentToggleCommandButton" Content="Disable/Enable" Width="120" Height="26" Background="#ffeaa7" Foreground="#2d3436" BorderBrush="#ffeaa7" BorderThickness="1" Grid.Column="1"/>
                            <Button x:Name="AgentResetCommandsButton" Content="Reset Commands" Width="120" Height="26" Background="#fab1a0" Foreground="#2d3436" BorderBrush="#fab1a0" BorderThickness="1" Grid.Column="2" Margin="10,0,0,0"/>
                            <Button x:Name="AgentUndoButton" Content="Undo Last Action" Width="130" Height="26" Background="#dfe6e9" Foreground="#2d3436" BorderBrush="#dfe6e9" BorderThickness="1" Grid.Column="3" Margin="10,0,0,0"/>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- ModelMind Tab -->
                <TabItem Header="ModelMind">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="300" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- ModelMind chat history (main area) -->
                        <RichTextBox x:Name="ModelMindHistory" Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto" IsReadOnly="True" Background="#f8fafd" FontSize="15" BorderBrush="#b3cef6" BorderThickness="1" />

                        <!-- Input and buttons row -->
                        <Grid Grid.Row="1" Grid.Column="0" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="170" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ModelMindInput" Height="32" MaxHeight="80" MinWidth="390" MaxWidth="600" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontSize="14" BorderBrush="#b3cef6" BorderThickness="1" Margin="0,0,10,0" Grid.Column="0"/>
                            <Button x:Name="ModelMindSendButton" Content="Send" Width="90" Height="32" Background="#00b894" Foreground="White" FontWeight="Bold" BorderBrush="#00b894" BorderThickness="1" FontSize="14" Grid.Column="1"/>
                            <Button x:Name="ApproveCodeButton" Content="Approve &amp; Run Code" Width="150" Height="32" Background="#e17055" Foreground="White" FontWeight="Bold" BorderBrush="#e17055" BorderThickness="1" FontSize="14" Margin="10,0,0,0" Grid.Column="2"/>
                        </Grid>

                        <!-- Sidebar for prompts -->
                        <GroupBox Header="Available Prompts" Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Margin="10,0,0,0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                            <TreeView x:Name="PromptTree" BorderBrush="#b3cef6" BorderThickness="1"/>
                        </GroupBox>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
